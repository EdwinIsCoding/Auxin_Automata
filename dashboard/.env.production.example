# Dashboard — Mainnet production (template)
# DO NOT commit .env.production with real values.
# Set these in Vercel's environment settings instead.
# This file is a template only.

# ── Solana / Anchor ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NEXT_PUBLIC_PROGRAM_ID=<mainnet program ID from programs/deployed_mainnet.json>
NEXT_PUBLIC_HARDWARE_WALLET=<mainnet hardware pubkey from initialise_mainnet.py>

# ── Bridge WebSocket ──────────────────────────────────────────────────────────
NEXT_PUBLIC_BRIDGE_WS_URL=wss://<VPS_DOMAIN>:8766
NEXT_PUBLIC_BRIDGE_HTTP_URL=https://<VPS_DOMAIN>:8767

# ── Digital twin ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_TWIN_WS_URL=wss://<VPS_DOMAIN>:8765

# ── Agent display ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENT_PUBKEY=<mainnet hardware pubkey>

# ── Observability ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
