# ── Solana / Anchor ───────────────────────────────────────────────────────────
# Helius RPC WebSocket URL for on-chain event subscriptions
NEXT_PUBLIC_HELIUS_RPC_URL=

# Deployed program ID (filled in after Phase 2A devnet deploy)
NEXT_PUBLIC_PROGRAM_ID=

# ── Bridge WebSocket ──────────────────────────────────────────────────────────
# URL of the Python bridge WebSocket broadcaster (off-chain live telemetry)
NEXT_PUBLIC_BRIDGE_WS_URL=ws://localhost:8766

# ── Digital twin WebSocket ────────────────────────────────────────────────────
# URL of the PyBullet frame stream (used when AUXIN_SOURCE=twin)
NEXT_PUBLIC_TWIN_WS_URL=ws://localhost:8765

# ── Observability ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
