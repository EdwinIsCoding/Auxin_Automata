# ── Solana / Anchor ───────────────────────────────────────────────────────────
# Helius RPC URL (HTTP + WebSocket) for on-chain event subscriptions (2C.6)
# Must be WebSocket-capable. Helius wss:// endpoint recommended.
# If unset, useProgramEvents is a no-op (mock mode).
NEXT_PUBLIC_HELIUS_RPC_URL=

# Agent pubkey shown in the Header (from run_bridge.py startup logs or deployed.json)
NEXT_PUBLIC_AGENT_PUBKEY=

# Deployed agentic_hardware_bridge program ID (set after Phase 2A devnet deploy)
# If unset, useProgramEvents is a no-op.
NEXT_PUBLIC_PROGRAM_ID=

# ── Bridge WebSocket ──────────────────────────────────────────────────────────
# Base URL of the Python bridge WebSocket broadcaster.
# The dashboard appends /ws automatically — do NOT include /ws here.
# Bridge listens at ws://<host>:8766/ws  (see sdk/src/auxin_sdk/bridge.py)
NEXT_PUBLIC_BRIDGE_WS_URL=ws://localhost:8766

# ── Bridge HTTP (healthz + invoice endpoint) ──────────────────────────────────
# URL of the Python bridge HTTP server (for /healthz and GET /invoice/latest).
# Bridge listens at http://<host>:8767  (see sdk/src/auxin_sdk/bridge.py)
NEXT_PUBLIC_BRIDGE_HTTP_URL=http://localhost:8767

# ── Digital twin WebSocket ────────────────────────────────────────────────────
# URL of the PyBullet JPEG frame stream (AUXIN_SOURCE=twin mode).
# Used by TwinViewport when live frame data is available.
NEXT_PUBLIC_TWIN_WS_URL=ws://localhost:8765

# ── Observability ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
