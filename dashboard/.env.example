# ── Cluster ───────────────────────────────────────────────────────────────────
# The active cluster is detected automatically from NEXT_PUBLIC_SOLANA_RPC_URL:
#   URL contains "mainnet" → MAINNET (green badge in Header)
#   Anything else          → DEVNET  (amber badge in Header)
#
# For local dev:    copy to .env.development  (loaded by: pnpm dev)
# For production:   set vars in Vercel dashboard (do NOT commit .env.production)

# ── Solana / Anchor ───────────────────────────────────────────────────────────
# Devnet:  https://api.devnet.solana.com  or  https://devnet.helius-rpc.com/?api-key=KEY
# Mainnet: https://mainnet.helius-rpc.com/?api-key=KEY
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_HELIUS_RPC_URL=

# Devnet program ID (deployed April 2026):
NEXT_PUBLIC_PROGRAM_ID=7sUSbF9zDN9QKVwA2ZGskg9gFgvbMuQpCdpt3hfgf1Mm

# Hardware wallet pubkey (shown in Header)
# Devnet:  from scripts/setup_devnet.py output
# Mainnet: trPhnio8TMxUCo6bRC25cyyo2htEGJmNLDcgzDizeq9
NEXT_PUBLIC_HARDWARE_WALLET=
NEXT_PUBLIC_AGENT_PUBKEY=

# ── Bridge WebSocket ──────────────────────────────────────────────────────────
# Local dev: ws://localhost:8766
# Production: wss://<VPS_DOMAIN>:8766
NEXT_PUBLIC_BRIDGE_WS_URL=ws://localhost:8766
NEXT_PUBLIC_BRIDGE_HTTP_URL=http://localhost:8767

# ── Digital twin ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_TWIN_WS_URL=ws://localhost:8765

# ── Observability ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
