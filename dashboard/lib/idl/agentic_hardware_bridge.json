          }
        ]
      }
    },
    {
      "name": "ComplianceEvent",
      "docs": [
        "Emitted by `log_compliance_event`.",
        "Never dropped — see CLAUDE.md compliance contract."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "agent",
            "type": "pubkey"
          },
          {
            "name": "hash",
            "type": "string"
          },
          {
            "name": "severity",
            "type": "u8"
          },
          {
            "name": "reason_code",
            "type": "u16"
          },
          {
            "name": "timestamp",
            "type": "i64"
          }
        ]
      }
    },
    {
      "name": "ComplianceLog",
      "docs": [
        "Immutable on-chain record of a compliance event.",
        "",
        "Seeds: `[b\"log\", agent.key().as_ref(), &slot.to_le_bytes()]`"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "agent",
            "docs": [
              "The HardwareAgent that triggered this event."
            ],
            "type": "pubkey"
          },
          {
            "name": "hash",
            "docs": [
              "Keccak-256 hex digest of the raw telemetry payload (max 64 chars)."
            ],
            "type": "string"
          },
          {
            "name": "severity",
            "docs": [
              "Severity level: 0 = DEBUG, 1 = INFO, 2 = WARN, 3 = CRITICAL."
            ],
            "type": "u8"
          },
          {
            "name": "reason_code",
            "docs": [
              "Application-defined reason code (e.g. 0x0001 = torque-limit)."
            ],
            "type": "u16"
          },
          {
            "name": "timestamp",
            "docs": [
              "Unix timestamp from Clock."
            ],
            "type": "i64"
          },
          {
            "name": "bump",
            "docs": [
              "Canonical PDA bump."
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "ComputePaymentEvent",
      "docs": [
        "Emitted by `stream_compute_payment` on every successful transfer."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "agent",
            "type": "pubkey"
          },
          {
            "name": "provider",
            "type": "pubkey"
          },
          {
            "name": "lamports",
            "type": "u64"
          },
          {
            "name": "timestamp",
            "type": "i64"
          }
        ]
      }
    },
    {
      "name": "ComputeProvider",
      "docs": [
        "PDA tracking aggregate lamports received by a compute provider.",
        "",
        "Seeds: `[b\"provider\", provider_pubkey.as_ref()]`",
        "Initialized lazily on first payment to a new provider."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "provider_pubkey",
            "type": "pubkey"
          },
          {
            "name": "total_received",
            "type": "u64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "HardwareAgent",
      "docs": [
        "PDA representing a registered autonomous hardware agent.",
        "",
        "Seeds: `[b\"agent\", owner.key().as_ref()]`"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "owner",
            "docs": [
              "Wallet authority — must sign init and whitelist-update instructions."
            ],
            "type": "pubkey"
          },
          {
            "name": "hardware_pubkey",
            "docs": [
              "Ed25519 key burned into the hardware module.",
              "Signs autonomous payment and compliance instructions."
            ],
            "type": "pubkey"
          },
          {
            "name": "compute_budget_lamports",
            "docs": [
              "Lifetime cap on compute payments (lamports).",
              "Also the SOL deposited into this PDA at init time."
            ],
            "type": "u64"
          },
          {
            "name": "lamports_spent",
            "docs": [
              "Running total of lamports disbursed via stream_compute_payment."
            ],
            "type": "u64"
          },
          {
            "name": "providers",
            "docs": [
              "Whitelisted compute providers; max `MAX_PROVIDERS` (8) entries."
            ],
            "type": {
              "vec": "pubkey"
            }
          },
          {
            "name": "created_at",
            "docs": [
              "Unix timestamp at account creation."
            ],
            "type": "i64"
          },
          {
            "name": "last_window_start_slot",
            "docs": [
              "Slot at which the current rate-limit window began."
            ],
            "type": "u64"
          },
          {
            "name": "window_tx_count",
            "docs": [
              "Transactions counted in the current rate-limit window."
            ],
            "type": "u16"
          },
          {
            "name": "bump",
            "docs": [
              "Canonical PDA bump."
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "ProviderWhitelistUpdatedEvent",
      "docs": [
        "Emitted by `update_provider_whitelist`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "agent",
            "type": "pubkey"
          },
          {
            "name": "provider",
            "type": "pubkey"
          },
          {
            "name": "added",
            "docs": [
              "true = added, false = removed."
            ],
            "type": "bool"
          },
          {
            "name": "timestamp",
            "type": "i64"
          }
        ]
      }
    },
    {
      "name": "WhitelistAction",
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Add"
          },
          {
            "name": "Remove"
          }
        ]
      }
    }
  ]
