# ── Simulation ────────────────────────────────────────────────────────────────
# Internal PyBullet simulation rate (Hz) — do not change without testing IK
PYBULLET_SIM_RATE_HZ=240

# Telemetry output rate (Hz) — must match MockSource default
TWIN_TELEMETRY_RATE_HZ=10

# ── Rendering ─────────────────────────────────────────────────────────────────
# Mode: video | ws | both
TWIN_MODE=ws

# WebSocket server port for JPEG frame stream (dashboard TwinViewport)
TWIN_WS_PORT=8765

# Output path for MP4 render (used when mode=video or mode=both)
TWIN_VIDEO_OUTPUT=./twin_demo.mp4

# Frames per second for MP4 output
TWIN_VIDEO_FPS=30
