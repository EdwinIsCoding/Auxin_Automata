[Unit]
Description=Auxin Automata Telemetry Bridge (ROS2 → SDK → Solana)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jetson
Environment="ROS_DOMAIN_ID=0"
Environment="AUXIN_SOURCE=ros2"
ExecStart=/bin/bash -c 'source /opt/ros/humble/setup.bash && source /home/jetson/auxin_ws/install/setup.bash && ros2 run auxin_edge telemetry_bridge_node'
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
