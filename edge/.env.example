# ── ROS2 ─────────────────────────────────────────────────────────────────────
# ROS2 domain ID (default 0; change if multiple robots on the same network)
ROS_DOMAIN_ID=0

# ── Telemetry bridge node ─────────────────────────────────────────────────────
# Joint state topic (vendor-specific; verify with `ros2 topic list`)
JOINT_STATES_TOPIC=/joint_states

# Telemetry publish rate in Hz (throttled from raw ROS2 rate)
TELEMETRY_RATE_HZ=2

# Stale telemetry timeout (seconds before emitting "stale_telemetry" flag)
STALE_TIMEOUT_S=1.0

# ── Safety watchdog node ──────────────────────────────────────────────────────
# Torque threshold (N·m) — watchdog triggers /emergency_stop above this value
# Must match the threshold used in the Gemini oracle (sdk/.env.example)
WATCHDOG_TORQUE_THRESHOLD=80.0

# Consecutive over-threshold frames required before e-stop
WATCHDOG_CONSECUTIVE_FRAMES=3

# ── Logging ───────────────────────────────────────────────────────────────────
# Grafana Loki endpoint for remote log forwarding (optional)
LOKI_URL=
