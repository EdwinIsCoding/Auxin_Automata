# ── Cluster Selection ─────────────────────────────────────────────────────────
# Controls which Solana cluster the bridge targets.
# devnet  (default) = existing Devnet deployment — free airdrops, safe for CI
# mainnet           = production deployment — REAL SOL, manual only
#
# Copy this file to .env.devnet or .env.mainnet and fill in real values.
# The bridge loads .env.devnet when AUXIN_CLUSTER=devnet (or unset).
# The bridge loads .env.mainnet when AUXIN_CLUSTER=mainnet.
# CI/GitHub Actions ONLY ever uses devnet.
AUXIN_CLUSTER=devnet

# ── Solana ────────────────────────────────────────────────────────────────────
# Devnet:   https://api.devnet.solana.com  (public, rate-limited)
#           https://devnet.helius-rpc.com/?api-key=YOUR_KEY  (preferred)
# Mainnet:  https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com
HELIUS_RPC_URL=
HELIUS_API_KEY=

# ── Anchor program ────────────────────────────────────────────────────────────
# Devnet program ID (deployed April 2026, do not change):
#   PROGRAM_ID=7sUSbF9zDN9QKVwA2ZGskg9gFgvbMuQpCdpt3hfgf1Mm
# Mainnet program ID: filled in by scripts/deploy_mainnet.sh
PROGRAM_ID=

# ── Hardware wallet ───────────────────────────────────────────────────────────
# Devnet:  ~/.config/auxin/hardware_devnet.json
# Mainnet: ~/.config/auxin/hardware_mainnet.json  (generated by initialise_mainnet.py)
# WARNING: never commit keypair files
HARDWARE_KEYPAIR_PATH=~/.config/auxin/hardware_devnet.json
HW_KEYPAIR_PATH=~/.config/auxin/hardware_devnet.json

# ── Provider ──────────────────────────────────────────────────────────────────
# Whitelisted provider pubkey for payments.
# Devnet: set after devnet initialise_agent.
# Mainnet: filled in by scripts/initialise_mainnet.py.
PROVIDER_PUBKEY=

# ── Telemetry source ──────────────────────────────────────────────────────────
# Options: mock | twin | ros2
# mock  = synthetic sine/cosine kinematics (no hardware needed)
# twin  = PyBullet simulation in /twin (start twin first)
# ros2  = live /joint_states from ROS2 on Jetson
AUXIN_SOURCE=mock

# ── Gemini oracle ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Claude API (treasury agent) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Privacy provider ──────────────────────────────────────────────────────────
# Options: direct | cloak | magicblock | umbra
AUXIN_PRIVACY=direct
CLOAK_PROGRAM_ID=
CLOAK_RELAY_URL=
MAGICBLOCK_API_URL=https://payments.magicblock.app
MAGICBLOCK_API_KEY=
MAGICBLOCK_CLUSTER=devnet
UMBRA_SIDECAR_URL=http://localhost:3002

# ── Bridge service ────────────────────────────────────────────────────────────
BRIDGE_WS_PORT=8766
BRIDGE_HEALTHZ_PORT=8767
AUXIN_MOCK_RATE_HZ=10
AUXIN_MOCK_ANOMALY_EVERY=12

# ── Financial intelligence ────────────────────────────────────────────────────
AUXIN_RISK_INTERVAL_S=60
AUXIN_TREASURY_INTERVAL_S=120
AUXIN_INVOICE_INTERVAL_H=24
AUXIN_INVOICE_DIR=/tmp/auxin_invoices

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
