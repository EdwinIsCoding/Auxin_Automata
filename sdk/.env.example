# ── Solana ────────────────────────────────────────────────────────────────────
# Helius RPC URL for Devnet (get a free key at https://helius.dev)
HELIUS_RPC_URL=

# Fallback public Devnet RPC (no key required, rate-limited)
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Hardware wallet ───────────────────────────────────────────────────────────
# Path to the hardware keypair JSON (generated by scripts/bootstrap_keypair.py)
# WARNING: never commit the actual keypair file
HW_KEYPAIR_PATH=~/.config/auxin/hardware.json

# ── Telemetry source ──────────────────────────────────────────────────────────
# Options: mock | twin | ros2
# mock  = synthetic sine/cosine kinematics (no hardware needed)
# twin  = PyBullet simulation in /twin (start twin first)
# ros2  = live /joint_states from ROS2 on Jetson
AUXIN_SOURCE=mock

# ── Gemini oracle ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Anchor program ────────────────────────────────────────────────────────────
# Filled in after Phase 2A devnet deploy (see programs/deployed.json)
PROGRAM_ID=

# ── Bridge service ────────────────────────────────────────────────────────────
# Port for the WebSocket broadcaster (dashboard live telemetry)
BRIDGE_WS_PORT=8766
# Port for the /healthz HTTP endpoint
BRIDGE_HEALTHZ_PORT=8767

# ── Financial Intelligence ────────────────────────────────────────────────────
# Claude API key for the AI treasury agent
ANTHROPIC_API_KEY=

# Risk scoring interval in seconds (default: 60)
AUXIN_RISK_INTERVAL_S=60

# Treasury analysis interval in seconds (default: 120)
AUXIN_TREASURY_INTERVAL_S=120

# Invoice generation interval in hours (default: 24)
AUXIN_INVOICE_INTERVAL_H=24

# Invoice PDF output directory (default: /tmp/auxin_invoices)
AUXIN_INVOICE_DIR=/tmp/auxin_invoices

# macOS only: weasyprint needs Homebrew GTK libs on $DYLD_LIBRARY_PATH
# Add this to your shell profile or run-bridge launcher:
#   export DYLD_LIBRARY_PATH="/opt/homebrew/lib:$DYLD_LIBRARY_PATH"

# ── Observability ─────────────────────────────────────────────────────────────
# Optional — leave blank to disable
SENTRY_DSN=
