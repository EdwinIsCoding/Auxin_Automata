AUXIN_CLUSTER=mainnet

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# ── Anchor program ────────────────────────────────────────────────────────────
# Filled in by scripts/deploy_mainnet.sh after deployment
PROGRAM_ID=<TO_BE_FILLED_AFTER_DEPLOYMENT>

# ── Hardware wallet ───────────────────────────────────────────────────────────
# Generated by scripts/initialise_mainnet.py — NEVER the same as hardware_devnet.json
HARDWARE_KEYPAIR_PATH=~/.config/auxin/hardware_mainnet.json

# ── Provider ──────────────────────────────────────────────────────────────────
# Filled in by scripts/initialise_mainnet.py after provider wallet is created
PROVIDER_PUBKEY=<TO_BE_FILLED_AFTER_DEPLOYMENT>

# ── Telemetry source ──────────────────────────────────────────────────────────
AUXIN_SOURCE=mock

# ── Gemini oracle ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── Claude API (treasury agent) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ── Bridge service ────────────────────────────────────────────────────────────
BRIDGE_WS_PORT=8766
BRIDGE_HEALTHZ_PORT=8767

# ── Financial intelligence ────────────────────────────────────────────────────
AUXIN_RISK_INTERVAL_S=60
AUXIN_TREASURY_INTERVAL_S=120
AUXIN_INVOICE_INTERVAL_H=24
AUXIN_INVOICE_DIR=/tmp/auxin_invoices

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
