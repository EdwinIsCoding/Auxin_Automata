!programs/deployed.json
!programs/deployed_devnet.json
!programs/deployed_mainnet.json

# ── Solana ───────────────────────────────────────────────────────────────────
test-ledger/
*.so.deploy
# Keypairs — never commit private keys
*.json.bak

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
# Dual-cluster env files — contain real keys, never commit
.env.devnet
.env.mainnet
# Keep example/template files
!**/.env.example
!**/.env.*.example
!**/.env.production.example

