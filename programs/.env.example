# ── Devnet RPC ────────────────────────────────────────────────────────────────
# Helius RPC URL (required for deploy and tests against Devnet)
HELIUS_RPC_URL=

# ── Deployer keypair ──────────────────────────────────────────────────────────
# Path to the deployer keypair JSON file.
# WARNING: never commit the actual keypair file.
DEPLOYER_KEYPAIR_PATH=~/.config/solana/id.json

# ── Program (filled in after deploy) ─────────────────────────────────────────
# Written to programs/deployed.json by scripts/deploy_devnet.sh
PROGRAM_ID=
